# ─────────────────────────────────────────────
# Supabase Environment Variables (Vercel + local)
# ─────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API

# Public URL (safe for frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Public anon key (safe for frontend — protected by RLS)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️ NEVER put SUPABASE_SERVICE_ROLE_KEY in frontend code or VITE_ vars
# It bypasses RLS and should only be used server-side
