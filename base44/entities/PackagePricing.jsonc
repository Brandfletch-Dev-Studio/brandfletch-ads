{
  "name": "PackagePricing",
  "type": "object",
  "properties": {
    "country": {
      "type": "string"
    },
    "currency": {
      "type": "string"
    },
    "symbol": {
      "type": "string"
    },
    "package": {
      "type": "string"
    },
    "daily": {
      "type": "number",
      "default": 0
    },
    "weekly": {
      "type": "number",
      "default": 0
    },
    "monthly": {
      "type": "number",
      "default": 0
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Optional description of this pricing package"
    }
  },
  "required": [
    "country",
    "package"
  ]
}