{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user",
        "campaign_manager",
        "finance"
      ],
      "default": "user"
    },
    "country": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "business_name": {
      "type": "string"
    },
    "business_type": {
      "type": "string"
    },
    "business_website": {
      "type": "string"
    },
    "business_industry": {
      "type": "string",
      "enum": [
        "retail",
        "food_beverage",
        "health_beauty",
        "technology",
        "real_estate",
        "education",
        "finance",
        "hospitality",
        "media_entertainment",
        "ngo",
        "professional_services",
        "other"
      ]
    },
    "business_description": {
      "type": "string"
    },
    "primary_goal": {
      "type": "string"
    },
    "fb_page_name": {
      "type": "string",
      "description": "Facebook Page name collected at onboarding"
    },
    "fb_page_url": {
      "type": "string",
      "description": "Facebook Page URL collected at onboarding"
    },
    "admin_notification_email": {
      "type": "string"
    },
    "notify_campaign_approved": {
      "type": "boolean",
      "default": true
    },
    "notify_campaign_rejected": {
      "type": "boolean",
      "default": true
    },
    "notify_payment_confirmed": {
      "type": "boolean",
      "default": true
    },
    "notify_campaign_completed": {
      "type": "boolean",
      "default": true
    },
    "notify_messages": {
      "type": "boolean",
      "default": true
    },
    "profile_photo": {
      "type": "string"
    },
    "cover_photo": {
      "type": "string"
    },
    "onboarded": {
      "type": "boolean",
      "default": false
    }
  }
}