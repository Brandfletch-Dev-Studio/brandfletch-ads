{
  "name": "DesignRequest",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "designer_id": {
      "type": "string"
    },
    "designer_name": {
      "type": "string",
      "description": "Full name or email of the assigned designer (denormalized for display)"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "target_audience": {
      "type": "string"
    },
    "brand_name": {
      "type": "string"
    },
    "preferred_dimensions": {
      "type": "string"
    },
    "preferred_style": {
      "type": "string"
    },
    "special_instructions": {
      "type": "string"
    },
    "design_type": {
      "type": "string",
      "enum": [
        "social_media_post",
        "flyer",
        "poster",
        "banner",
        "business_card",
        "logo",
        "brochure",
        "presentation",
        "custom",
        "other"
      ]
    },
    "request_type": {
      "type": "string",
      "enum": [
        "retainer",
        "per_design"
      ],
      "default": "per_design"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "submitted",
        "under_review",
        "assigned",
        "in_progress",
        "awaiting_feedback",
        "revision_requested",
        "approved",
        "delivered",
        "completed",
        "cancelled"
      ],
      "default": "draft"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "urgent"
      ],
      "default": "medium"
    },
    "revision_count": {
      "type": "number",
      "default": 0
    },
    "max_revisions": {
      "type": "number",
      "default": 2
    },
    "revision_comments": {
      "type": "string"
    },
    "due_date": {
      "type": "string",
      "format": "date"
    },
    "reference_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deliverable_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "draft_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "client_notes": {
      "type": "string"
    },
    "designer_notes": {
      "type": "string"
    },
    "admin_notes": {
      "type": "string"
    },
    "price": {
      "type": "number"
    },
    "currency": {
      "type": "string",
      "default": "USD"
    },
    "submitted_date": {
      "type": "string",
      "format": "date-time"
    },
    "completed_date": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "user_id",
    "title",
    "design_type"
  ]
}