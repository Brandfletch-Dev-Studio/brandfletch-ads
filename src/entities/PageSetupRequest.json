{
  "name": "PageSetupRequest",
  "type": "object",
  "properties": {
    "user_id": { "type": "string" },
    "country": { "type": "string" },
    "currency": { "type": "string" },
    "business_name": { "type": "string" },
    "products_services": { "type": "string" },
    "business_location": { "type": "string" },
    "whatsapp_number": { "type": "string" },
    "email": { "type": "string" },
    "logo_urls": { "type": "array", "items": { "type": "string" } },
    "additional_notes": { "type": "string" },
    "payment_method": { "type": "string" },
    "payment_reference": { "type": "string" },
    "payment_proof_url": { "type": "string" },
    "amount_paid": { "type": "number" },
    "status": {
      "type": "string",
      "enum": ["pending_payment", "paid", "in_progress", "completed", "cancelled"],
      "default": "pending_payment"
    },
    "admin_notes": { "type": "string" }
  },
  "required": ["business_name", "products_services", "business_location", "whatsapp_number", "email"]
}