{
  "name": "Service",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["service", "product"],
      "default": "service",
      "description": "Whether this is a service or a physical/digital product"
    },
    "category": {
      "type": "string",
      "enum": ["page_setup", "ads_management", "content_creation", "consulting", "other"]
    },
    "price_usd": { "type": "number", "default": 25 },
    "image_url": { "type": "string" },
    "required_fields": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of field labels the client must fill in when ordering (e.g. 'Phone Number', 'Business Name')"
    },
    "is_active": { "type": "boolean", "default": true },
    "sort_order": { "type": "number", "default": 0 }
  },
  "required": ["name", "price_usd"]
}