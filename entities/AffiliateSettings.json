{
  "name": "AffiliateSettings",
  "type": "object",
  "properties": {
    "default_commission_type": {
      "type": "string",
      "enum": [
        "fixed",
        "percentage"
      ],
      "default": "fixed",
      "description": "Default type for all services unless overridden"
    },
    "default_fixed_amount": {
      "type": "number",
      "default": 10000,
      "description": "Default fixed commission per sale (MWK)"
    },
    "default_percentage": {
      "type": "number",
      "default": 5,
      "description": "Default % commission (0-100)"
    },
    "default_currency": {
      "type": "string",
      "default": "MWK"
    },
    "meta_ads_commission_type": {
      "type": "string",
      "enum": [
        "global",
        "fixed",
        "percentage"
      ],
      "default": "global",
      "description": "'global' = inherit default, 'fixed' or 'percentage' = override"
    },
    "meta_ads_fixed_amount": {
      "type": "number"
    },
    "meta_ads_percentage": {
      "type": "number"
    },
    "graphic_design_commission_type": {
      "type": "string",
      "enum": [
        "global",
        "fixed",
        "percentage"
      ],
      "default": "global"
    },
    "graphic_design_fixed_amount": {
      "type": "number"
    },
    "graphic_design_percentage": {
      "type": "number"
    },
    "social_media_commission_type": {
      "type": "string",
      "enum": [
        "global",
        "fixed",
        "percentage"
      ],
      "default": "global"
    },
    "social_media_fixed_amount": {
      "type": "number"
    },
    "social_media_percentage": {
      "type": "number"
    },
    "web_dev_commission_type": {
      "type": "string",
      "enum": [
        "global",
        "fixed",
        "percentage"
      ],
      "default": "global"
    },
    "web_dev_fixed_amount": {
      "type": "number"
    },
    "web_dev_percentage": {
      "type": "number"
    },
    "recurring_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Enable recurring commissions on repeat payments from referred clients"
    },
    "recurring_type": {
      "type": "string",
      "enum": [
        "fixed",
        "percentage"
      ],
      "default": "fixed",
      "description": "Type for recurring commission calculation"
    },
    "recurring_fixed_amount": {
      "type": "number",
      "default": 2000,
      "description": "Fixed amount per recurring payment"
    },
    "recurring_percentage": {
      "type": "number",
      "default": 3,
      "description": "% of each recurring payment"
    },
    "recurring_max_months": {
      "type": "number",
      "default": 12,
      "description": "Max months to pay recurring commission (0 = unlimited)"
    },
    "recurring_applies_to": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Which services qualify for recurring (e.g. ['meta_ads','graphic_design'])"
    },
    "minimum_payout": {
      "type": "number",
      "default": 5000
    },
    "minimum_payout_currency": {
      "type": "string",
      "default": "MWK"
    },
    "payout_cooldown_hours": {
      "type": "number",
      "default": 48
    },
    "program_enabled": {
      "type": "boolean",
      "default": true
    },
    "block_self_referrals": {
      "type": "boolean",
      "default": true
    },
    "one_commission_per_client": {
      "type": "boolean",
      "default": true
    },
    "cookie_duration_days": {
      "type": "number",
      "default": 30
    },
    "welcome_message": {
      "type": "string"
    },
    "terms_text": {
      "type": "string"
    }
  }
}