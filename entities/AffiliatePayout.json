{
  "name": "AffiliatePayout",
  "properties": {
    "affiliate_id": {
      "type": "string"
    },
    "affiliate_name": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "currency": {
      "type": "string",
      "default": "MWK"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "airtel_money",
        "tnm_mpamba",
        "bank_transfer"
      ]
    },
    "payment_details": {
      "type": "string",
      "description": "Account number or details"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "processing",
        "completed",
        "rejected"
      ],
      "default": "pending"
    },
    "notes": {
      "type": "string"
    },
    "processed_date": {
      "type": "string"
    },
    "transaction_reference": {
      "type": "string"
    }
  },
  "type": "object"
}